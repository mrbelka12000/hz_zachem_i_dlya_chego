HTTP_PORT=8080

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hz_zachem_storage
POSTGRES_SSLMODE=disable

# RabbitMQ is optional — leave RABBITMQ_URL empty to skip its
# initialization. Set all three when budget recompute / alert flows
# need to publish events.
RABBITMQ_URL=
RABBITMQ_EXCHANGE=
RABBITMQ_QUEUE=

WORKER_INTERVAL=1h

AUTH_JWT_SECRET=replace-with-32+byte-random-secret
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=720h
AUTH_COOKIE_NAME=session
AUTH_COOKIE_DOMAIN=
AUTH_SECURE_COOKIE=false

# Semicolon-separated origin list (env-tag delimiter is ';').
CORS_ALLOWED_ORIGINS=http://localhost:3000

CSRF_SECRET=replace-with-32+byte-random-secret
